# Receiver runtime configuration

# Login username for the web UI and Basic Auth API access.
APP_USERNAME=admin

# Login password for the web UI and Basic Auth API access.
APP_PASSWORD=change-me

# Address and port used by the HTTP server.
BIND_ADDRESS=0.0.0.0:8080

# Optional managed storage path.
# If empty or unset, Receiver uses ./storage next to the running binary.
# FILE_ROOT=/var/lib/receiver
