#!/bin/bash
set -e

cd "$(dirname "$0")"

has_command() {
    command -v "$1" >/dev/null 2>&1
}

has_rust_target() {
    local target=$1

    rustup target list --installed 2>/dev/null | grep -Fxq "$target"
}

select_cargo_command() {
    local target=$1

    case "$target" in
        "i686-unknown-linux-musl")
            if has_command "i686-linux-musl-gcc"; then
                echo "cargo build"
            elif has_command "cargo-zigbuild" && has_command "zig"; then
                echo "cargo zigbuild"
            else
                return 1
            fi
            ;;
        "aarch64-unknown-linux-musl")
            if has_command "aarch64-linux-musl-gcc"; then
                echo "cargo build"
            elif has_command "cargo-zigbuild" && has_command "zig"; then
                echo "cargo zigbuild"
            else
                return 1
            fi
            ;;
        "x86_64-unknown-linux-musl")
            if has_command "x86_64-linux-musl-gcc"; then
                echo "cargo build"
            elif has_command "cargo-zigbuild" && has_command "zig"; then
                echo "cargo zigbuild"
            else
                return 1
            fi
            ;;
        *)
            echo "cargo build"
            ;;
    esac
}

build_target() {
    local target=$1
    local output_name=$2
    local cargo_cmd
    
    echo "Building for $target..."
    
    # Build frontend
    echo "Building frontend..."
    cd frontend
    npm ci --silent 2>/dev/null || true
    npm run build
    cd ..
    
    # Build backend
    echo "Building backend for $target..."
    cd backend
    if ! has_rust_target "$target"; then
        cd ..
        echo "Build failed for $target"
        echo "Rust target $target is not installed."
        echo "Run: rustup target add $target"
        return 1
    fi

    if ! cargo_cmd=$(select_cargo_command "$target"); then
        cd ..
        echo "Build failed for $target"
        echo "Missing cross-compiler for $target."
        echo "Install the target musl gcc, or install both zig and cargo-zigbuild."
        return 1
    fi

    echo "Using: $cargo_cmd --release --target $target"
    if $cargo_cmd --release --target "$target" 2>&1; then
        cd ..
        # Copy binary to root
        mv "backend/target/$target/release/receiver" "$output_name"
        echo "Build complete: $output_name"
    else
        cd ..
        echo "Build failed for $target"
        return 1
    fi
}

case "$1" in
    "linux-86"|"linux 86"|"86")
        build_target "i686-unknown-linux-musl" "receiver-i686"
        ;;
    "linux-64"|"linux 64"|"64")
        build_target "x86_64-unknown-linux-musl" "receiver"
        ;;
    "linux-arm"|"linux arm"|"arm")
        build_target "aarch64-unknown-linux-musl" "receiver-arm64"
        ;;
    "all")
        mkdir -p artifacts
        build_target "i686-unknown-linux-musl" "artifacts/receiver-i686-unknown-linux-musl"
        build_target "x86_64-unknown-linux-musl" "artifacts/receiver-x86_64-unknown-linux-musl"
        build_target "aarch64-unknown-linux-musl" "artifacts/receiver-aarch64-unknown-linux-musl"
        ;;
    *-*-*)
        target="$1"
        output_name="artifacts/receiver-$target"
        mkdir -p artifacts
        build_target "$target" "$output_name"
        ;;
    *)
        echo "Usage: $0 {linux-86|linux-64|linux-arm|all|<target>}"
        echo "  linux-86: builds i686-unknown-linux-musl"
        echo "  linux-64: builds x86_64-unknown-linux-musl"
        echo "  linux-arm: builds aarch64-unknown-linux-musl"
        echo "  all: build all targets"
        echo "  <target>: full target name (e.g., x86_64-unknown-linux-musl)"
        exit 1
        ;;
esac
